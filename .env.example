# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- Anthropic API ---
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Application settings ---
# Set to "development" on local machines, "production" on deployment hosts.
FRANKENBOTE_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- SFTP publishing ---
# Connection details for the static-site host (any provider with SFTP).
# Examples: shared webhosting, VPS, NAS web server, cloud storage with SFTP.
SFTP_HOST=
SFTP_USERNAME=
SFTP_PRIVATE_KEY_PATH=
SFTP_REMOTE_ROOT=
# Set this only if your private key is passphrase-protected:
SFTP_PRIVATE_KEY_PASSPHRASE=
# Defaults to 22 if omitted:
SFTP_PORT=22