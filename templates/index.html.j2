<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Der Frankenbote — Archiv</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:wght@500;600;700&display=swap">
    <link rel="stylesheet" href="assets/style.css">
    <link rel="icon" type="image/svg+xml" href="assets/frankenrechen.svg">
</head>
<body>
<main>

    <header class="masthead">
        <img class="masthead__icon"
             src="assets/frankenrechen.svg"
             alt=""
             width="56" height="56">
        <div>
            <h1 class="masthead__title">
                Der Frankenbote
                <span class="masthead__subtitle">Archiv</span>
            </h1>
        </div>
    </header>

    <section class="archive">
        <h2 class="archive__title">Letzte Ausgaben</h2>

        {% if editions %}
        <ul class="archive__list">
            {% for ed in editions %}
            <li>
                <a href="{{ ed.filename }}">
                    <span class="date">{{ ed.date_label }}</span>
                    <span class="meta">— {{ ed.article_count }} Artikel</span>
                </a>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p>Noch keine Ausgaben vorhanden.</p>
        {% endif %}
    </section>

    <footer class="colophon">
        <p>Persönlicher Wochendigest aus Franken</p>
    </footer>

</main>
</body>
</html>