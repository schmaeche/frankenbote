<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Der Frankenbote — {{ edition.edition_date }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:wght@500;600;700&display=swap">
    <link rel="stylesheet" href="../assets/style.css">
    <link rel="icon" type="image/svg+xml" href="../assets/frankenrechen.svg">
</head>
<body>
<main>

    <header class="masthead">
        <a href="../index.html">
            <img class="masthead__icon"
                 src="../assets/frankenrechen.svg"
                 alt=""
                 width="56" height="56">
        </a>
        <div>
            <h1 class="masthead__title">
                Der Frankenbote
                <span class="masthead__subtitle">
                    Ausgabe {{ edition.edition_date | calendar_week }} · {{ edition.stats.selected }} Artikel
                </span>
            </h1>
        </div>
    </header>

    {% for section in edition.sections %}
    <section class="section">
        <h2 class="section__title">{{ section.display_name }}</h2>

        {% for item in section.articles %}
        <article class="article">
            <h3 class="article__title">
                <a href="{{ item.article.link }}" target="_blank" rel="noopener noreferrer">
                    {{ item.article.title }}
                </a>
            </h3>

            {% if item.wrap_up %}
            {% for paragraph in item.wrap_up | paragraphs %}
            <p class="article__summary">{{ paragraph }}</p>
            {% endfor %}
            {% elif item.ai_summary %}
            <p class="article__summary">{{ item.ai_summary }}</p>
            {% elif item.article.summary %}
            <p class="article__summary">{{ item.article.summary | safe }}</p>
            {% endif %}

            <div class="article__meta">
                <span class="article__priority">{{ priority_labels.get(item.priority.value, item.priority.value) }}</span>
                <span class="article__source">{{ item.article.source_name }}</span>
                {% if item.article.published %}
                <span class="article__date">
                    {{ item.article.published.strftime('%d.%m. %H:%M') }}
                </span>
                {% endif %}
            </div>
            
            {% if item.rationale %}
            <details class="article__rationale-details">
                <summary></summary>
                <p class="article__rationale">{{ item.rationale }}</p>
            </details>
            {% endif %}

        </article>
        {% endfor %}
    </section>
    {% endfor %}

    <footer class="colophon">
        <p>
            <a href="../index.html">Archiv</a> ·
            Erstellt am {{ generated_at.strftime('%d.%m.%Y %H:%M') }} ·
            Persönlicher Wochendigest aus Franken
        </p>
    </footer>

</main>
</body>
</html>